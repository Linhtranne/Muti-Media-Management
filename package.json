{
  "name": "mediaops-composability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "typecheck:test": "npm run typecheck:test -w packages/shared-contracts && npm run typecheck:test -w apps/orchestrator",
    "test": "node run-tests.mjs",
    "lint": "npm run typecheck && npm run lint:eslint",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "dev:all": "node scripts/dev-all.mjs",
    "start:orchestrator": "node --env-file=.env.local apps/orchestrator/dist/server.js",
    "start:ngrok": "ngrok http 3000",
    "seed:slack-admin": "node seed-workspace-member.cjs",
    "rabbitmq:reset-slack": "node delete-rabbit-queues.cjs",
    "db:apply": "node apply-migration.cjs",
    "verify:db": "npx @insforge/cli db query \"SELECT 1 AS ok\"",
    "ai-sdlc:check": "node scripts/ai-sdlc-check.mjs",
    "ai-sdlc:validate": "node scripts/ai-sdlc-validate.mjs",
    "ai-sdlc:smoke": "node scripts/runtime-smoke.mjs",
    "story:detect": "node scripts/story-detect.mjs",
    "story:validate": "node scripts/ai-sdlc-validate.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "eslint": "^10.4.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1"
  }
}
